{
  "version": 2,
  "builds": [
    { "src": "public/dashboard.html", "use": "@vercel/static" },
    { "src": "public/dashboard.css", "use": "@vercel/static" },
    { "src": "public/dashboard.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/public/dashboard.html" },
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    { "src": "/dashboard.css", "dest": "/public/dashboard.css" },
    { "src": "/dashboard.js", "dest": "/public/dashboard.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
